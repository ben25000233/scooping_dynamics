<?xml version="1.0" ?>
<robot name="bowl">
  <link name="bowl">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <mesh filename="real_bowl.obj"/>
      </geometry>
    </visual>
   
    <inertial>
      <mass value="0.5"/> 
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
</robot>
        